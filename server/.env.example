# ================================
# CareerX Server Environment
# ================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# → Create free cluster at https://cloud.mongodb.com
# → Network Access: Add your IP (or 0.0.0.0/0 for dev)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/careerx?retryWrites=true&w=majority

# JWT Secrets (generate strong random strings for production)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth (optional — not wired yet)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Providers (at least one required for AI features)
# Groq — Free, fast. Get key at https://console.groq.com
GROQ_API_KEY=
# Google Gemini — Free tier. Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# JDoodle API — Free cloud compiler (200 req/day)
# Get free keys at https://www.jdoodle.com/compiler-api/
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:3000

# Email (SMTP) — optional in development
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM="CareerX" <noreply@careerx.dev>
